generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model StudentProfile {
  id          String       @id @default(uuid())
  userId      String       @unique
  quizAnswers QuizAnswer[]
  results     Result[]
}

model Dimension {
  id              String            @id @default(uuid())
  name            String            @unique
  questions       Question[]
  options         Option[]
  metierRelations MetierDimension[]
}

model Question {
  id          String       @id @default(uuid())
  text        String       // Le libellé de la question
  category    String?      // "Aspirations", "Stress"
  order       Int          @unique // Pour l'ordre d'affichage
  imageUrl    String?      @default("/Quiz.png")
  
  options     Option[]     // Une question a plusieurs choix possibles
  quizAnswers QuizAnswer[]

  // Relation avec Dimension (si tu veux garder une dimension principale par question)
  dimensionId String
  dimension   Dimension    @relation(fields: [dimensionId], references: [id])
}

model Option {
  id            String    @id @default(uuid())
  letter        String    // "A", "B", "C", "D"
  title         String    // "Le leader organisé"
  description   String?   // "Je planifie, distribue les tâches..."
  
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  dimensionName String
  dimension     Dimension @relation(fields: [dimensionName], references: [name])
}

model Metier {
  id         String            @id @default(uuid())
  name       String
  domainId   String
  domain     Domain            @relation(fields: [domainId], references: [id])
  dimensions MetierDimension[]
  results    Result[]
}

model MetierDimension {
  id          String    @id @default(uuid())
  metierId    String
  metier      Metier    @relation(fields: [metierId], references: [id])
  dimensionId String
  dimension   Dimension @relation(fields: [dimensionId], references: [id])
  score       Int
}

model Domain {
  id      String   @id @default(uuid())
  name    String   @unique
  metiers Metier[]
}

model QuizAnswer {
  id         String         @id @default(uuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id])
  questionId String
  question   Question       @relation(fields: [questionId], references: [id])
  value      Int
}

model Result {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  metierId  String
  metier    Metier         @relation(fields: [metierId], references: [id])
  score     Int
}